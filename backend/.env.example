# Copy this file to backend/.env for local development.
# Never commit backend/.env with real credentials.

# AI provider used by the primary fast dashboard path.
AI_PROVIDER=groq
GROQ_API_KEY=your_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# Optional legacy/local semantic-planner settings.
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:3b
OLLAMA_NUM_CTX=2048

# AI timeouts and limits.
AI_SEMANTIC_ENABLED=true
AI_SEMANTIC_TIMEOUT_SECONDS=8
AI_CHAT_ENABLED=true
AI_CHAT_TIMEOUT_SECONDS=8
AI_CLUSTER_NAMING_ENABLED=true
AI_CLUSTER_NAMING_TIMEOUT_SECONDS=4
AI_MAX_COLUMN_CARDS=25
AI_MAX_RECOMMENDED_CHARTS=5

# API limits and cache.
MAX_UPLOAD_FILES=5
MAX_UPLOAD_BYTES=20971520
MAX_PAGE_SIZE=500
ANALYTICS_CACHE_TTL_SECONDS=1800
ANALYTICS_CACHE_MAX_ITEMS=20
ANALYTICS_MAX_DEFAULT_MAIN_CHARTS=6
ANALYTICS_MAX_CORE_CHARTS=6

# Development CORS. Use explicit origins for deployed environments.
CORS_ORIGINS=*
CORS_ALLOW_CREDENTIALS=false
